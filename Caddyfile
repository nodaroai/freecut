:3000 {
    root * /srv
    encode gzip zstd
    try_files {path} /index.html
    file_server

    # Content-hashed build assets (/assets/main-*.js etc.) are immutable for a
    # given URL — cache them hard so repeat loads are fast.
    @assets path /assets/*
    header @assets Cache-Control "public, max-age=31536000, immutable"

    # Everything else (index.html / SPA routes, sw.js, manifest) must revalidate
    # so a new deploy is picked up on the next load or embed session.
    @revalidate not path /assets/*
    header @revalidate Cache-Control "no-cache"

    header {
        Cross-Origin-Embedder-Policy "credentialless"
        Cross-Origin-Opener-Policy "same-origin-allow-popups"
        Cross-Origin-Resource-Policy "cross-origin"
        Content-Security-Policy "frame-ancestors 'self' https://app.nodaro.ai https://next.nodaro.ai https://studio.nodaro.ai http://localhost:* https://*.up.railway.app"
        X-Frame-Options ""
    }
}
